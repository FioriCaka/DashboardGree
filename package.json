{
  "name": "gree-node-react",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:server dev:client",
    "dev:server": "npm --workspace server run dev",
    "dev:client": "npm --workspace client run dev",
    "start": "npm --workspace server start",
    "build": "npm --workspace client run build",
    "db:migrate": "npm --workspace server run db:migrate",
    "db:seed": "npm --workspace server run db:seed"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
